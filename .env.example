# =============================================================================
# NoSite Prospector — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NEVER commit .env or .env.local to git.
# See docs/API_SETUP_GUIDE.md for instructions on obtaining each value.
# =============================================================================


# -----------------------------------------------------------------------------
# Google Cloud APIs
# See: docs/API_SETUP_GUIDE.md § Google Cloud
# -----------------------------------------------------------------------------

# Restricted API key for Google Places API (backend use only — IP-restricted)
# Used by: /src/services/googlePlaces.ts
GOOGLE_PLACES_KEY=your_google_places_api_key_here

# Restricted API key for Google Geocoding API (backend use only — IP-restricted)
# Used by: /src/services/geocoding.ts
# Note: Can be the same key as GOOGLE_PLACES_KEY if both APIs are enabled on one key.
GOOGLE_GEOCODING_KEY=your_google_geocoding_api_key_here


# -----------------------------------------------------------------------------
# Yelp Fusion API
# See: docs/API_SETUP_GUIDE.md § Yelp
# -----------------------------------------------------------------------------

# Yelp Fusion API key (backend use only)
# Rate limits: 5,000 calls/day, 5 calls/second
# Used by: /src/services/yelp.ts
YELP_API_KEY=your_yelp_fusion_api_key_here


# -----------------------------------------------------------------------------
# Supabase
# See: docs/API_SETUP_GUIDE.md § Supabase
# -----------------------------------------------------------------------------

# Your Supabase project URL — safe to expose to the browser
# Format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key — safe to expose to the browser
# Used by: /src/lib/supabaseClient.ts (client-side session management)
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase service role key — BACKEND ONLY, never expose to the browser
# Bypasses Row Level Security; use only in server-side API routes
# Used by: /src/lib/supabaseAdmin.ts
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# PostgreSQL connection string (pooled, via Supabase connection pooler)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Used by: Prisma (all database queries)
DATABASE_URL=postgresql://postgres.your-project-ref:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Direct (non-pooled) connection string — used only for Prisma migrations
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres


# -----------------------------------------------------------------------------
# Redis (Upstash)
# See: docs/API_SETUP_GUIDE.md § Redis
# -----------------------------------------------------------------------------

# Upstash Redis REST URL
# Format: https://<instance-name>.upstash.io
# Used by: /src/lib/redis.ts (quota counters, BullMQ job queue)
REDIS_URL=https://your-instance.upstash.io

# Upstash Redis REST token (keep secret)
REDIS_TOKEN=your_upstash_redis_token_here


# -----------------------------------------------------------------------------
# Stripe
# See: docs/API_SETUP_GUIDE.md § Stripe (to be added in billing milestone)
# -----------------------------------------------------------------------------

# Stripe secret key — BACKEND ONLY
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe publishable key — safe to expose to the browser
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe webhook signing secret (from `stripe listen` or Stripe dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Stripe price IDs for subscription plans
STRIPE_PRO_MONTHLY_PRICE_ID=price_your_pro_monthly_price_id_here
STRIPE_PRO_ANNUAL_PRICE_ID=price_your_pro_annual_price_id_here


# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------

# Base URL of the deployed app (no trailing slash)
# Local: http://localhost:3000
# Production: https://yourapp.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
NODE_ENV=development


# -----------------------------------------------------------------------------
# Sentry (error tracking)
# -----------------------------------------------------------------------------

SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@o0.ingest.sentry.io/0


# -----------------------------------------------------------------------------
# Optional: Mapbox (geocoding fallback)
# Only needed if you upgrade from OSM Nominatim to Mapbox.
# See: docs/API_SETUP_GUIDE.md § Mapbox / OSM Nominatim
# -----------------------------------------------------------------------------

# MAPBOX_PUBLIC_TOKEN=pk.your_mapbox_public_token_here
